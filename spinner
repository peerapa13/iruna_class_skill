<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>วงล้อสุ่มอาชีพ - Iruna Online</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=Noto+Sans+Thai:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --gold: #d4a843;
            --gold-light: #f0c96a;
            --accent: #3fc8f9;
            --deep: #0a0812;
            --card-bg: rgba(30, 41, 59, 0.8);
            --text: #e8e0f0;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: var(--deep);
            color: var(--text);
            font-family: 'Noto Sans Thai', sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            padding: 40px 20px;
            overflow-x: hidden;
        }

        /* Background Effect */
        #stars {
            position: fixed; inset: 0; z-index: -1;
            background: radial-gradient(ellipse at 50% 50%, rgba(124,58,237,0.1) 0%, transparent 80%);
        }

        .header {
            text-align: center;
            margin-bottom: 30px;
        }

        .title {
            font-family: 'Cinzel Decorative', serif;
            font-size: 32px;
            background: linear-gradient(135deg, var(--gold-light) 0%, var(--gold) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 10px;
        }

        .container {
            background: var(--card-bg);
            padding: 40px;
            border-radius: 20px;
            border: 1px solid rgba(212, 168, 67, 0.3);
            box-shadow: 0 0 30px rgba(0,0,0,0.5);
            text-align: center;
            max-width: 500px;
            width: 100%;
        }

        #wheel-container {
            position: relative;
            margin: 20px auto;
            width: 320px;
            height: 320px;
        }

        canvas {
            max-width: 100%;
            height: auto;
        }

        /* เข็มชี้กงล้อ */
        .pointer {
            position: absolute;
            top: -15px;
            left: 50%;
            transform: translateX(-50%);
            width: 0;
            height: 0;
            border-left: 15px solid transparent;
            border-right: 15px solid transparent;
            border-top: 25px solid var(--accent);
            z-index: 10;
            filter: drop-shadow(0 0 5px var(--accent));
        }

        .spin-btn {
            margin-top: 30px;
            padding: 15px 50px;
            font-size: 20px;
            font-weight: bold;
            background: linear-gradient(135deg, var(--gold-light), var(--gold));
            border: none;
            border-radius: 50px;
            color: #000;
            cursor: pointer;
            transition: 0.3s;
            box-shadow: 0 5px 15px rgba(212, 168, 67, 0.4);
        }

        .spin-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 0 20px var(--gold);
        }

        .spin-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        #result {
            margin-top: 25px;
            font-size: 24px;
            color: var(--accent);
            min-height: 36px;
            font-weight: 700;
            text-shadow: 0 0 10px rgba(63, 200, 249, 0.3);
        }

        .back-link {
            margin-top: 40px;
            color: var(--gold);
            text-decoration: none;
            font-size: 14px;
            border-bottom: 1px solid transparent;
            transition: 0.3s;
        }

        .back-link:hover {
            border-bottom: 1px solid var(--gold);
        }
    </style>
</head>
<body>
    <div id="stars"></div>

    <div class="header">
        <h1 class="title">iruna online</h1>
        <p style="color: #9d8fb8;">สุ่มเลือกอาชีพของคุณ</p>
    </div>

    <div class="container">
        <div id="wheel-container">
            <div class="pointer"></div>
            <canvas id="wheelCanvas" width="320" height="320"></canvas>
        </div>
        
        <button id="spinBtn" class="spin-btn">หมุนวงล้อ!</button>
        <div id="result"></div>
    </div>

    <a href="index.html" class="back-link">← กลับไปหน้าฐานข้อมูลสกิล</a>

    <script>
        const jobs = [
            "พาลาดิน", "จอมดาบ", "บีทไนท์", "นักแม่นธนู", 
            "นักฆ่า", "ซัมมอนเนอร์", "จอมขมังเวทย์", "เนโครแมนเซอร์", 
            "ผู้วิเศษ", "สังฆราช", "นักพรต", "เซอร์แวน", 
            "นินจา", "ซามุไร", "นักดนตรี", "นักเล่นแร่แปรธาตุ"
        ];

        const canvas = document.getElementById("wheelCanvas");
        const ctx = canvas.getContext("2d");
        const spinBtn = document.getElementById("spinBtn");
        const resultDiv = document.getElementById("result");

        let currentAngle = 0;
        const numSegments = jobs.length;
        const arcSize = (2 * Math.PI) / numSegments;

        // ฟังก์ชันวาดวงล้อ
        function drawWheel() {
            const centerX = canvas.width / 2;
            const centerY = canvas.height / 2;
            const radius = centerX - 10;

            ctx.clearRect(0, 0, canvas.width, canvas.height);

            for (let i = 0; i < numSegments; i++) {
                const angle = currentAngle + (i * arcSize);
                
                // สลับสีช่อง
                ctx.fillStyle = (i % 2 === 0) ? "#1e293b" : "#0f172a";
                ctx.strokeStyle = "#d4a843";
                ctx.lineWidth = 1;

                ctx.beginPath();
                ctx.moveTo(centerX, centerY);
                ctx.arc(centerX, centerY, radius, angle, angle + arcSize);
                ctx.closePath();
                ctx.fill();
                ctx.stroke();

                // วาดข้อความ
                ctx.save();
                ctx.translate(centerX, centerY);
                ctx.rotate(angle + arcSize / 2);
                ctx.textAlign = "right";
                ctx.fillStyle = "#e8e0f0";
                ctx.font = "bold 10px 'Noto Sans Thai'";
                ctx.fillText(jobs[i], radius - 15, 5);
                ctx.restore();
            }
        }

        function spin() {
            spinBtn.disabled = true;
            resultDiv.innerText = "กำลังสุ่ม...";
            
            const extraSpins = Math.floor(Math.random() * 5) + 5; // หมุนอย่างน้อย 5-10 รอบ
            const randomAngle = Math.random() * (2 * Math.PI);
            const totalRotation = (extraSpins * 2 * Math.PI) + randomAngle;
            
            const duration = 4000; // 4 วินาที
            const start = performance.now();
            const initialAngle = currentAngle;

            function animate(time) {
                const elapsed = time - start;
                const progress = Math.min(elapsed / duration, 1);
                
                // Ease Out effect
                const easeOut = 1 - Math.pow(1 - progress, 3);
                
                currentAngle = initialAngle + (totalRotation * easeOut);
                
                drawWheel();

                if (progress < 1) {
                    requestAnimationFrame(animate);
                } else {
                    finishSpin();
                }
            }

            requestAnimationFrame(animate);
        }

        function finishSpin() {
            spinBtn.disabled = false;
            
            // เข็มอยู่ที่ตำแหน่ง -PI/2 (90 องศาด้านบน)
            const normalizedAngle = (currentAngle % (2 * Math.PI));
            const pointerAngle = (1.5 * Math.PI - normalizedAngle) % (2 * Math.PI);
            const finalPointerAngle = pointerAngle < 0 ? pointerAngle + 2 * Math.PI : pointerAngle;
            
            const winningIndex = Math.floor(finalPointerAngle / arcSize);
            resultDiv.innerText = "ผลลัพธ์ของคุณคือ: " + jobs[winningIndex];
        }

        spinBtn.addEventListener("click", spin);

        // วาดครั้งแรก
        drawWheel();
    </script>
</body>
</html>
